# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is committed as the template.
#
# This one file feeds three readers:
#   - docker-compose services (postgres/minio/migrate/createbuckets)
#   - the orchestrator binary   (internal/orchestrator/config.go -> Load())
#   - worker containers          (env passed through by the provisioner)

# =====================================================================
# Infrastructure (read by docker-compose)
# =====================================================================

# ---- Postgres ----
# The postgres image REQUIRES POSTGRES_PASSWORD. POSTGRES_USER/DB are optional
# (default to "postgres") but set them explicitly so the DSN is unambiguous.
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=change-me
POSTGRES_DB=crawler

# ---- MinIO ----
# Root credentials for the MinIO server + the mc client in createbuckets.
# Must be at least 3 chars (user) / 8 chars (password) or MinIO refuses to start.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-min-8-chars

# Bucket the init container creates. Also read by the app (below) as the
# output bucket, so it is defined once here.
MINIO_BUCKET=crawler-output

# =====================================================================
# Application (read by the orchestrator binary + passed to workers)
# =====================================================================

# Which provisioner to use: "docker" (local dev) or "hetzner" (prod).
PROVISIONER=docker

# Postgres DSN. Uses the compose service name "postgres", NOT localhost,
# because this same value is handed to worker containers, which resolve
# "postgres" on the crawler_orch network. For the host-run orchestrator to
# resolve it too, either add "127.0.0.1 postgres" to /etc/hosts (the port is
# published on loopback) or run the orchestrator on the crawler_orch network.
DB_URL=postgres://orchestrator:change-me@postgres:5432/crawler?sslmode=disable

# Object storage the workers write results to. Locally this is the compose
# MinIO; the access/secret keys are the MinIO root creds above. Same
# host-vs-container hostname note as DB_URL applies to "minio".
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-min-8-chars
MINIO_USE_SSL=false

# Comma-separated categories to run one goroutine per, per worker.
# Match whatever scripts/seed.sql enqueues.
CATEGORIES=news,blogs,forums

# ---- Sizing / lease / retry (all optional; defaults shown) ----
# x = ceil(max_category_items * AVG_ITEM_SECONDS / DEADLINE_SECONDS),
# clamped to [MIN_WORKERS, MAX_WORKERS].
# DEADLINE_SECONDS=14400
# AVG_ITEM_SECONDS=1
# MIN_WORKERS=1
# MAX_WORKERS=20
# MONITOR_INTERVAL=15s
# LEASE_DURATION=90s
# MAX_ATTEMPTS=5

# =====================================================================
# DockerProvisioner (required when PROVISIONER=docker)
# =====================================================================

# The locally built worker image (docker build -f Dockerfile.worker).
WORKER_IMAGE=crawler-worker:latest
# The compose network workers attach to (see docker-compose.yaml).
WORKER_NETWORK=crawler_orch

# =====================================================================
# Prod deploy (deploy/docker-compose.prod.yaml) -- see deploy/README.md
# =====================================================================

# Interface Postgres binds to on the always-on VM. Local dev leaves this
# unset (defaults to 127.0.0.1 in the local compose file). In prod, set
# this to the VM's Hetzner private network IP so worker VMs can reach it
# -- never 0.0.0.0, since that would expose Postgres publicly.
# POSTGRES_BIND_ADDR=10.0.1.2

# =====================================================================
# HetznerProvisioner (required when PROVISIONER=hetzner)
# =====================================================================
# When PROVISIONER=hetzner, DB_URL and MINIO_ENDPOINT above must be
# reachable from the worker VMs -- typically private-network addresses (see
# HETZNER_PRIVATE_NETWORK_ID) or a public object-storage endpoint, not the
# compose service names.
#
# HETZNER_API_TOKEN=            # Read & Write API token
# HETZNER_SERVER_TYPE=cx23      # worker VM type (must match snapshot arch)
# HETZNER_IMAGE=                # pre-baked snapshot ID from scripts/build-snapshot.sh
# HETZNER_LOCATION=nbg1         # optional; empty lets Hetzner pick
# HETZNER_SSH_KEYS=             # optional, comma-separated key names/IDs
# HETZNER_TTL_BUFFER=300s       # optional; added to DEADLINE_SECONDS for VM self-destruct
# HETZNER_PRIVATE_NETWORK_ID=   # optional numeric ID; attaches workers to a private network
